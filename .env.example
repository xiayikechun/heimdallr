# Heimdallr V3 Environment Configuration

# ============================================
# Backend Configuration
# ============================================

# Debug mode (set to false in production)
DEBUG=false

# Number of uvicorn workers
WORKERS=2

# Database connection string
# SQLite (default, single-server deployment):
DATABASE_DSN=sqlite:////app/data/heimdallr.db
# MySQL (multi-server or high-availability deployment):
# DATABASE_DSN=mysql+pymysql://heimdallr:heimdallr_password@mysql:3306/heimdallr

# JWT Secret Key (MUST be changed in production!)
SECRET_KEY=CHANGE_THIS_SECRET_KEY_IN_PRODUCTION

# Domain name (for CORS and URL generation)
DOMAIN=localhost

# ============================================
# Port Configuration
# ============================================

# Backend API port (host machine)
BACKEND_PORT=9000

# Frontend web port (host machine)
FRONTEND_PORT=80

# HTTPS port (if using SSL)
# HTTPS_PORT=443

# ============================================
# MySQL Configuration (Optional)
# ============================================
# Uncomment these if you're using MySQL instead of SQLite

# MYSQL_ROOT_PASSWORD=heimdallr_root_password
# MYSQL_DATABASE=heimdallr
# MYSQL_USER=heimdallr
# MYSQL_PASSWORD=heimdallr_password

# ============================================
# Advanced Configuration
# ============================================

# CORS allowed origins (comma-separated)
# CORS_ORIGINS=https://example.com,https://www.example.com

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# LOG_LEVEL=INFO

# Session timeout in seconds (default: 86400 = 24 hours)
# SESSION_TIMEOUT=86400
