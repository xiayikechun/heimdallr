# Development environment variables for Heimdallr
# Copy this to .env and modify as needed

# Application settings
DEBUG=true
PORT=9000
WORKERS=1
SECRET_KEY=dev-secret-key-change-in-production-please

# Database configuration (uncomment to use MySQL instead of SQLite)
# DATABASE_DSN=mysql+pymysql://heimdallr:heimdallr123@db:3306/heimdallr

# SQLite configuration (default for development)
SQLITE_PATH=/app/data/heimdallr.db

# Version information (will be set by Docker build)
# HEIMDALLR_VERSION=dev
# COMMIT_ID=dev