# Heimdallr Production Environment Configuration
# Copy this file to .env and modify the values as needed

# =============================================================================
# BASIC CONFIGURATION
# =============================================================================

# Domain name for the application (used by frontend for API calls and display)
# This should be your actual domain name (e.g., heimdallr.example.com)
DOMAIN=localhost

# Application version and build info
HEIMDALLR_VERSION=3.0.0
COMMIT_ID=prod

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# JWT Secret Key - CHANGE THIS IN PRODUCTION!
# Generate a secure random key: openssl rand -hex 32
SECRET_KEY=your_super_secure_secret_key_here

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Database type selection
# Set to "true" to use MySQL, "false" to use SQLite
USE_MYSQL=true

# MySQL Configuration (only used if USE_MYSQL=true)
MYSQL_ROOT_PASSWORD=your_mysql_root_password
MYSQL_DATABASE=heimdallr
MYSQL_USER=heimdallr
MYSQL_PASSWORD=your_mysql_password

# Database DSN (Data Source Name)
# For MySQL: mysql+pymysql://username:password@mysql:3306/database_name
# For SQLite: sqlite:////app/data/heimdallr.db
DATABASE_DSN=mysql+pymysql://heimdallr:your_mysql_password@mysql:3306/heimdallr

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Number of backend worker processes
# Recommended: 1-2 per CPU core, adjust based on your server specs
WORKERS=2

# HTTP and HTTPS ports
HTTP_PORT=80
HTTPS_PORT=443

# =============================================================================
# DEVELOPMENT/DEBUG CONFIGURATION
# =============================================================================

# Set to true only for debugging (never in production!)
DEBUG=false

# =============================================================================
# OPTIONAL SSL/HTTPS CONFIGURATION
# =============================================================================

# SSL certificate paths (uncomment if using HTTPS)
# SSL_CERT_PATH=./data/ssl/cert.pem
# SSL_KEY_PATH=./data/ssl/key.pem

# =============================================================================
# BACKUP AND MONITORING
# =============================================================================

# Backup directory for database dumps (optional)
# BACKUP_DIR=./data/backups

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# =============================================================================
# INSTRUCTIONS
# =============================================================================

# 1. Copy this file: cp .env.example .env
# 2. Generate a secure SECRET_KEY: openssl rand -hex 32
# 3. Set your DOMAIN to your actual domain name
# 4. Configure database settings (MySQL recommended for production)
# 5. Adjust WORKERS based on your server capacity
# 6. Save the file and run: docker-compose -f docker-compose.prod.yaml up -d

# For SQLite setup (simpler, good for small deployments):
# - Set USE_MYSQL=false
# - Set DATABASE_DSN=sqlite:////app/data/heimdallr.db
# - Remove --profile mysql from docker-compose command

# For MySQL setup (recommended for production):
# - Set USE_MYSQL=true  
# - Configure MYSQL_* variables
# - Set DATABASE_DSN with your MySQL credentials
# - Run with --profile mysql flag